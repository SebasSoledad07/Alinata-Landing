---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: "website" | "article";
}

const {
  title = "Alinata Bakery | Repostería Artesanal y Postres Personalizados",
  description = "Alinata Bakery — Postres artesanales que endulzan tus celebraciones más especiales. Tortas personalizadas, cupcakes gourmet, macarons y más. ¡Pide el tuyo hoy!",
  image = "/logo-alinata.jpg",
  url = Astro.url.href,
  type = "website",
} = Astro.props;

const siteName = "Alinata Bakery";
const twitterHandle = "@alinatakbery"; // actualiza si tienes uno

// Schema.org JSON-LD — Local Business + Bakery
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["Bakery", "LocalBusiness"],
  name: siteName,
  description,
  url,
  image,
  priceRange: "$$",
  servesCuisine: "Repostería Artesanal",
  telephone: "+58-XXX-XXXXXXX", // actualiza con el número real
  address: {
    "@type": "PostalAddress",
    addressCountry: "VE",
  },
  sameAs: [
    // Agrega tus redes sociales aquí, ej.:
    // "https://www.instagram.com/alinatakbery",
  ],
  offers: [
    {
      "@type": "Offer",
      name: "Tortas Personalizadas",
      description: "Tortas artesanales diseñadas especialmente para tu celebración",
      priceCurrency: "USD",
    },
    {
      "@type": "Offer",
      name: "Cupcakes Gourmet",
      description: "Cupcakes elaborados con ingredientes premium",
      priceCurrency: "USD",
    },
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "5",
    reviewCount: "50",
  },
});
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="keywords" content="repostería artesanal, tortas personalizadas, cupcakes gourmet, postres, pastelería, Alinata, celebraciones, bodas, cumpleaños" />
<meta name="author" content="Alinata Bakery" />
<meta name="robots" content="index, follow" />
<meta name="language" content="Spanish" />
<link rel="canonical" href={url} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="es_ES" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={url} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />
<meta name="twitter:site" content={twitterHandle} />

<!-- Favicon -->
<link rel="icon" type="image/jpeg" href="/logo-alinata.jpg" />
<link rel="apple-touch-icon" href="/logo-alinata.jpg" />

<!-- Preconnect for performance (contribuye al SEO técnico) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- Schema.org JSON-LD Structured Data -->
<script type="application/ld+json" set:html={jsonLd} />
