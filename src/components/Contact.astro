  <script>
    // Form submission handler for WhatsApp
    const contactForm = document.getElementById("contact-form");
    if (contactForm) {
      contactForm.addEventListener("submit", function (e) {
        e.preventDefault();

        // Número de WhatsApp de Alinata (reemplaza con el número real)
        // Formato: código de país + número sin espacios ni símbolos
        const whatsappNumber = "+584161168586"; // Reemplaza con el número real

        // Obtener datos del formulario
        const nombre =
          (document.getElementById("nombre") as HTMLInputElement | null)
            ?.value || "";
        const telefono =
          (document.getElementById("telefono") as HTMLInputElement | null)
            ?.value || "";
        const evento =
          (document.getElementById("evento") as HTMLSelectElement | null)
            ?.value || "";
        const fecha =
          (document.getElementById("fecha") as HTMLInputElement | null)
            ?.value || "";
        const personas =
          (document.getElementById("personas") as HTMLInputElement | null)
            ?.value || "";
        const mensaje =
          (document.getElementById("mensaje") as HTMLTextAreaElement | null)
            ?.value || "";

        // Crear mensaje para WhatsApp
        let whatsappMessage = `🍰 *Nueva Consulta - Alinata Bakery* 🍰\n\n`;
        whatsappMessage += `👤 *Nombre:* ${nombre}\n`;
        whatsappMessage += `📞 *Teléfono:* ${telefono}\n`;
        whatsappMessage += `🎉 *Tipo de Evento:* ${evento}\n`;

        if (fecha) {
          const fechaFormateada = new Date(fecha).toLocaleDateString("es-ES", {
            weekday: "long",
            year: "numeric",
            month: "long",
            day: "numeric",
          });
          whatsappMessage += `📅 *Fecha del Evento:* ${fechaFormateada}\n`;
        }

        if (personas) {
          whatsappMessage += `👥 *Número de Personas:* ${personas}\n`;
        }

        whatsappMessage += `\n💬 *Mensaje:*\n${mensaje}\n\n`;
        whatsappMessage += `¡Espero tu respuesta! 😊`;

        // Codificar el mensaje para URL
        const encodedMessage = encodeURIComponent(whatsappMessage);

        // Crear URL de WhatsApp
        const whatsappURL = `https://wa.me/${whatsappNumber}?text=${encodedMessage}`;

        // Abrir WhatsApp
        window.open(whatsappURL, "_blank");

        // Mostrar mensaje de confirmación
        alert(
          "¡Perfecto! Te estamos redirigiendo a WhatsApp para enviar tu consulta.",
        );

        // Opcional: limpiar formulario después de enviar
        (this as HTMLFormElement).reset();
      });
    }
  </script>
