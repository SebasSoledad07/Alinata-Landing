---
const testimonials = [
  {
    name: "María González",
    role: "Mamá de cumpleañera",
    rating: 5,
    comment: "¡Increíble! La torta de cumpleaños de mi hija fue exactamente lo que soñé. Alina superó todas mis expectativas con cada detalle.",
    initial: "M",
  },
  {
    name: "Carlos Rodríguez",
    role: "Cliente frecuente",
    rating: 5,
    comment: "Los brownies y la torta de chocolate son simplemente adictivos. Ya no compro en ningún otro lugar. ¡Son los mejores!",
    initial: "C",
  },
  {
    name: "Ana Martínez",
    role: "Organizadora de eventos",
    rating: 5,
    comment: "Profesionalismo y calidad excepcional. Cada vez que necesito postres para mis eventos, confío plenamente en Alinata Bakery.",
    initial: "A",
  },
  {
    name: "Luisa Pereira",
    role: "Cumpleañera feliz",
    rating: 5,
    comment: "La torta Red Velvet de mi cumpleaños fue un hit total. Todos los invitados preguntaron dónde la hicieron. ¡Gracias, Alina!",
    initial: "L",
  },
  {
    name: "Jesús Hernández",
    role: "Papá de cumpleañero",
    rating: 5,
    comment: "La torta beso de ángel que pedimos para el cumpleaños de mi hijo dejó a todos pidiendo más. Extraordinaria.",
    initial: "J",
  },
  {
    name: "Valentina Torres",
    role: "Cliente fiel",
    rating: 5,
    comment: "La marquesa de parchita es algo que no había probado igual en ningún lado. Un sabor único y una textura perfecta.",
    initial: "V",
  },
  {
    name: "Roberto Castillo",
    role: "Gerente de empresa",
    rating: 5,
    comment: "Pedimos los mini cakes para un evento corporativo y fueron un éxito rotundo. Presentación impecable y sabor inigualable.",
    initial: "R",
  },
  {
    name: "Gabriela Morales",
    role: "Maestra de primaria",
    rating: 5,
    comment: "Pedí la torta de zanahoria sin muchas expectativas y quedé completamente enamorada. El frosting de queso crema es divino.",
    initial: "G",
  },
  {
    name: "Pedro Suárez",
    role: "Chef aficionado",
    rating: 5,
    comment: "Como amante de la repostería, puedo decir que la torta de maíz de Alinata tiene una textura perfecta. Un trabajo artesanal de verdad.",
    initial: "P",
  },
  {
    name: "Daniela Rivas",
    role: "Influencer gastronómica",
    rating: 5,
    comment: "El cuchaeable oreo es puro vicio en capas. Lo compartí con mi comunidad y todas mis seguidoras quedaron enamoradas.",
    initial: "D",
  },
];
---

<section id="testimonios" class="py-24 bg-white overflow-hidden">
  <div class="container mx-auto px-4 mb-12">
    <div class="text-center space-y-4">
      <span class="inline-block bg-rose-100 text-rose-700 px-5 py-2 rounded-full text-sm font-semibold tracking-wide uppercase">
        Testimonios
      </span>
      <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight">
        Lo que Dicen Nuestros Clientes
      </h2>
      <p class="text-lg text-gray-500 max-w-xl mx-auto">
        Cada opinión es una historia de felicidad que nos motiva a seguir endulzando vidas.
      </p>
    </div>
  </div>

  <!-- Marquee track wrapper (two rows, opposite directions) -->
  <div class="space-y-5 select-none">

    <!-- Row 1 → left -->
    <div class="marquee-wrapper" aria-hidden="true">
      <div class="marquee-track marquee-left">
        {[...testimonials, ...testimonials].map((t) => (
          <div class="testimonial-card flex-shrink-0 w-80 bg-white border border-rose-100 rounded-2xl p-6 shadow-sm mx-3 space-y-4">
            <!-- Stars -->
            <div class="flex gap-0.5">
              {Array.from({ length: t.rating }).map(() => (
                <svg class="w-4 h-4 fill-amber-400" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <!-- Comment -->
            <p class="text-sm text-gray-600 leading-relaxed italic">"{t.comment}"</p>
            <!-- Author -->
            <div class="flex items-center gap-3 pt-1">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-rose-400 to-pink-500 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
                {t.initial}
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900">{t.name}</p>
                <p class="text-xs text-gray-400">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Row 2 → right (reversed subset for variety) -->
    <div class="marquee-wrapper" aria-hidden="true">
      <div class="marquee-track marquee-right">
        {[...testimonials.slice(5), ...testimonials.slice(0, 5), ...testimonials.slice(5), ...testimonials.slice(0, 5)].map((t) => (
          <div class="testimonial-card flex-shrink-0 w-80 bg-rose-50 border border-rose-100 rounded-2xl p-6 shadow-sm mx-3 space-y-4">
            <div class="flex gap-0.5">
              {Array.from({ length: t.rating }).map(() => (
                <svg class="w-4 h-4 fill-amber-400" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-sm text-gray-600 leading-relaxed italic">"{t.comment}"</p>
            <div class="flex items-center gap-3 pt-1">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-pink-400 to-rose-500 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
                {t.initial}
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900">{t.name}</p>
                <p class="text-xs text-gray-400">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  /* Fade edges */
  .marquee-wrapper {
    position: relative;
    overflow: hidden;
  }
  .marquee-wrapper::before,
  .marquee-wrapper::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }
  .marquee-wrapper::before {
    left: 0;
    background: linear-gradient(to right, white, transparent);
  }
  .marquee-wrapper::after {
    right: 0;
    background: linear-gradient(to left, white, transparent);
  }

  /* Tracks */
  .marquee-track {
    display: flex;
    width: max-content;
  }

  .marquee-left {
    animation: scrollLeft 40s linear infinite;
  }
  .marquee-right {
    animation: scrollRight 45s linear infinite;
  }

  /* Pause on hover */
  .marquee-wrapper:hover .marquee-track {
    animation-play-state: paused;
  }

  @keyframes scrollLeft {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes scrollRight {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
